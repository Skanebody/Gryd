# Supabase — projet à créer (DISCOVERY point ouvert O1). Jamais de secret en dur.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Clé SERVICE-ROLE — SERVEUR UNIQUEMENT, jamais NEXT_PUBLIC_. Requise par la file
# de revue des signalements (/admin/signalements, RPC admin_reports_* de 0046).
# Absente → la page dit « console non branchée » plutôt que d'afficher un faux zéro.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Console admin /admin (DÉMO LOCALE — pas un système d'auth de production) ──
# Identifiant de connexion admin (défaut dev : admin@gryd.run).
ADMIN_EMAIL=
# Mot de passe admin (défaut dev : gryd-s0-fondateur). À définir hors dev.
ADMIN_PASSWORD=
# Clé HMAC-SHA256 du cookie de session `gryd_admin` (défaut dev : dev-only-secret).
# Générer : openssl rand -hex 32
ADMIN_SESSION_SECRET=

# ─── PostHog (events §8 / O3) — projet UE (RGPD, cf. politique de confidentialité) ──
# Clé projet PUBLIQUE (phc_…), depuis eu.posthog.com → Settings → Project.
# Absente → analytics no-op. C'est une clé client (write-only), pas un secret.
NEXT_PUBLIC_POSTHOG_KEY=
# Host UE par défaut si absent. NE PAS mettre us.i.posthog.com (données hors UE).
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
