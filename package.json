{
  "name": "klaim",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "typecheck": "npm run typecheck --workspaces --if-present",
    "sync:rules": "node scripts/sync-game-rules.mjs",
    "deploy:staging": "node scripts/deploy-staging.mjs",
    "deploy:staging:dry": "node scripts/deploy-staging.mjs --dry-run",
    "setup:eas": "node scripts/setup-eas-env.mjs",
    "check:secrets": "node scripts/check-no-secrets.mjs",
    "ship:staging": "node scripts/ship-staging.mjs",
    "test:functions": "deno test --allow-read supabase/functions/"
  }
}
